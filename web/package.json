{
  "name": "agate-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Static SPA for agate. No server, no secrets — creds come from the Cognito identity exchange at runtime.",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/copy-pyodide.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/client-bedrock-agentcore": "^3.1067.0",
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@aws-sdk/client-cognito-identity": "^3.700.0",
    "@aws-sdk/client-s3vectors": "^3.1067.0",
    "@fontsource/atkinson-hyperlegible": "^5.2.8",
    "@smithy/signature-v4": "^5.4.6",
    "dompurify": "^3.4.11",
    "katex": "^0.17.0",
    "marked": "^18.0.5",
    "pyodide": "^314.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "happy-dom": "^20.10.2",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}

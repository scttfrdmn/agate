{
  "name": "agg-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Static SPA for aws-genai-gateway. No server, no secrets — creds come from the Cognito identity exchange at runtime.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agentcore": "^3.1067.0",
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@aws-sdk/client-cognito-identity": "^3.700.0",
    "@aws-sdk/client-s3vectors": "^3.1067.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "happy-dom": "^20.10.2",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
